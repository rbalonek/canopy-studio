# Copy this file to .env.local and fill in the values.
# .env.local is gitignored — never commit real keys or the DB password.

# --- Data provider toggle ---------------------------------------------------
# "mock"     — in-memory fixtures (default, no backend needed)
# "supabase" — read from Supabase (local or hosted, depending on URL)
VITE_DATA_PROVIDER=mock

# --- Supabase (client-side) -------------------------------------------------
# These two are read by the browser; the publishable key is safe to ship to
# the client — real security is Postgres RLS. When pointing at local, use the
# values printed by `supabase start`; when pointing at hosted, use the values
# from the project's API Keys page.
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_PUBLISHABLE_KEY=

# --- Supabase (CLI / migrations, not shipped to the client) -----------------
# Only needed when running `supabase db push` / other admin CLI actions
# against the hosted project. Not read by the browser.
SUPABASE_DB_PASSWORD=
